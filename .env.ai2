# AI2 本地并行测试环境变量覆盖
# 使用方法:
#   后端: $env:CODEX_PORT=8701; $env:CODEX_FRONTEND_ORIGIN="http://127.0.0.1:9701"; uvicorn app.main:app --host 127.0.0.1 --port $env:CODEX_PORT
#   前端: $env:FRONTEND_PORT=9701; $env:API_TARGET="http://127.0.0.1:8701"; npx vite
#
# 默认值: 后端 8700 / 前端 9700 (由 config.py 和 vite.config.ts 内置)
CODEX_PORT=8701
CODEX_FRONTEND_ORIGIN=http://127.0.0.1:9701
FRONTEND_PORT=9701
API_TARGET=http://127.0.0.1:8701
